<resources>
    <!-- Base application theme. -->
    <style name="Theme.BillsProjectionV2" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.BillsProjectionV2.Small" parent="Theme.BillsProjectionV2">
        <item name="text_info_size">@dimen/font_size_small</item>
        <item name="text_heading_size">@dimen/font_size_heading_small</item>
        <item name="text_size_normal">@dimen/font_size_normal_small</item>
        <item name="text_size_title">@dimen/font_size_title_small</item>
        <item name="title_text_size">@dimen/font_size_title_small</item>
        <item name="text_size_calc">@dimen/font_size_calc_small</item>
    </style>

    <style name="Theme.BillsProjectionV2.Medium" parent="Theme.BillsProjectionV2">
        <item name="text_info_size">@dimen/font_size_medium</item>
        <item name="text_heading_size">@dimen/font_size_heading_medium</item>
        <item name="text_size_normal">@dimen/font_size_normal_medium</item>
        <item name="text_size_title">@dimen/font_size_title_medium</item>
        <item name="title_text_size">@dimen/font_size_title_medium</item>
        <item name="text_size_calc">@dimen/font_size_calc_medium</item>
    </style>

    <style name="Theme.BillsProjectionV2.Large" parent="Theme.BillsProjectionV2">
        <item name="text_info_size">@dimen/font_size_large</item>
        <item name="text_heading_size">@dimen/font_size_heading_large</item>
        <item name="text_size_normal">@dimen/font_size_normal_large</item>
        <item name="text_size_title">@dimen/font_size_title_large</item>
        <item name="title_text_size">@dimen/font_size_title_large</item>
        <item name="text_size_calc">@dimen/font_size_calc_large</item>
    </style>
</resources>